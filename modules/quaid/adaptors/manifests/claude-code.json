{
  "schema": "quaid-adapter-install/v1",
  "id": "claude-code",
  "name": "Claude Code",
  "install": {
    "selectLabel": "Claude Code",
    "selectHint": "hooks + OAuth for Claude Code CLI",
    "sortOrder": 30,
    "modelDefaults": {
      "anthropic": {
        "deep": "claude-sonnet-4-5",
        "fast": "claude-haiku-4-5"
      },
      "openai": {
        "deep": "gpt-4o",
        "fast": "gpt-4o-mini"
      },
      "openrouter": {
        "deep": "gpt-4o",
        "fast": "gpt-4o-mini"
      },
      "together": {
        "deep": "gpt-4o",
        "fast": "gpt-4o-mini"
      },
      "ollama": {
        "deep": "llama3.1:70b",
        "fast": "llama3.1:8b"
      }
    }
  },
  "runtime": {
    "instancePrefix": "claude-code-",
    "python": {
      "module": "adaptors.claude_code.adapter",
      "class": "ClaudeCodeAdapter"
    }
  },
  "scripts": {
    "preinstall": "./hooks/preinstall.mjs",
    "postinstall": "./hooks/postinstall.mjs"
  }
}
