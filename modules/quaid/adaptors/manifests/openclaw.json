{
  "schema": "quaid-adapter-install/v1",
  "id": "openclaw",
  "name": "OpenClaw",
  "install": {
    "selectLabel": "OpenClaw",
    "selectHint": "gateway-integrated runtime",
    "sortOrder": 20,
    "modelDefaults": {
      "anthropic": {
        "deep": "claude-sonnet-4-5",
        "fast": "claude-haiku-4-5"
      },
      "openai": {
        "deep": "gpt-4o",
        "fast": "gpt-4o-mini"
      },
      "openrouter": {
        "deep": "gpt-4o",
        "fast": "gpt-4o-mini"
      },
      "together": {
        "deep": "gpt-4o",
        "fast": "gpt-4o-mini"
      },
      "ollama": {
        "deep": "llama3.1:70b",
        "fast": "llama3.1:8b"
      }
    }
  },
  "runtime": {
    "instancePrefix": "openclaw-",
    "python": {
      "module": "adaptors.openclaw.adapter",
      "class": "OpenClawAdapter"
    }
  },
  "scripts": {
    "preinstall": "./hooks/preinstall.mjs",
    "postinstall": "./hooks/postinstall.mjs"
  }
}
