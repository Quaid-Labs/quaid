{
  "schema": "quaid-adapter-install/v1",
  "id": "standalone",
  "name": "Standalone",
  "install": {
    "selectLabel": "Standalone",
    "selectHint": "local-only runtime (default)",
    "sortOrder": 10,
    "modelDefaults": {
      "anthropic": {
        "deep": "claude-haiku-4-5",
        "fast": "claude-haiku-4-5"
      },
      "openai": {
        "deep": "gpt-4o",
        "fast": "gpt-4o-mini"
      },
      "openrouter": {
        "deep": "gpt-4o",
        "fast": "gpt-4o-mini"
      },
      "together": {
        "deep": "gpt-4o",
        "fast": "gpt-4o-mini"
      },
      "ollama": {
        "deep": "llama3.1:70b",
        "fast": "llama3.1:8b"
      }
    }
  },
  "runtime": {
    "instancePrefix": "standalone",
    "python": {
      "module": "lib.adapter",
      "class": "StandaloneAdapter"
    }
  },
  "scripts": {
    "preinstall": "./hooks/preinstall.mjs",
    "postinstall": "./hooks/postinstall.mjs"
  }
}
