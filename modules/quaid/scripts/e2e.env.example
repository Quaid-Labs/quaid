# Optional override for where bootstrap lives.
# Example: QUAID_BOOTSTRAP_ROOT=./modules/quaid

# Optional repo-root local dev config. Relative paths inside that file resolve
# from its configured devRoot, not from your shell cwd.
# Example: QUAID_DEV_LOCAL_CONFIG=./.quaid-dev.local.json

# Optional override for profile files used by the E2E runner.
# Example: QUAID_E2E_PROFILE_SRC=modules/quaid/profiles/runtime-profile.local.quaid.json
# Example: QUAID_E2E_PROFILE_TEST=modules/quaid/profiles/runtime-profile.local.quaid.json
# Example: QUAID_E2E_PROFILE_PATH=modules/quaid/profiles/runtime-profile.local.quaid.json

# Optional OpenClaw ref override for bootstrap/e2e runtime.
# Default in runner is currently v2026.3.22.
# QUAID_E2E_OPENCLAW_REF=v2026.3.22

# Optional API keys if your bootstrap/profile setup resolves auth from env.
# Required for --auth-path openai-api
# OPENAI_API_KEY=
# Required for --auth-path anthropic-api
# ANTHROPIC_API_KEY=
